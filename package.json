  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:next\" \"npm run dev:api\"",
    "dev:next": "next dev --turbopack",
    "dev:api": "cd backend && ./venv/bin/python -m uvicorn main:app --reload --port 8000 --host 127.0.0.1",
